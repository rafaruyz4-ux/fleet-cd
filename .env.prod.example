# Variáveis da stack de produção (docker-compose.prod.yml).
# Copie para .env.prod e troque TODOS os segredos antes de subir:
#   cp .env.prod.example .env.prod
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

# ===== Banco =====
POSTGRES_USER=fleet
POSTGRES_PASSWORD=TROQUE-esta-senha-forte
POSTGRES_DB=fleet_cd

# ===== Porta pública do dashboard (Nginx) =====
WEB_PORT=8080

# ===== CORS =====
# Com o Nginx servindo o front e fazendo proxy de /api, tudo é mesma origem.
# Restrinja ao domínio público se a API for exposta diretamente.
CORS_ORIGINS=*

# ===== JWT (gere com: openssl rand -hex 32) =====
JWT_ACCESS_SECRET=TROQUE-gere-um-segredo-de-32-bytes
JWT_REFRESH_SECRET=TROQUE-gere-outro-segredo-de-32-bytes
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# ===== Worker sem_gps =====
WORKER_SEM_GPS_ENABLED=true

# ===== Admin inicial (criado no primeiro boot pelo seed) =====
SEED_ADMIN_NOME=Administrador
SEED_ADMIN_EMAIL=admin@cd.local
SEED_ADMIN_SENHA=TROQUE-a-senha-do-admin
