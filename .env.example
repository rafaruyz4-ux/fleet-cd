# ===== Servidor =====
NODE_ENV=development
PORT=3000
# Origens permitidas no CORS (separadas por vírgula). Use * apenas em dev.
CORS_ORIGINS=http://localhost:5173

# ===== Banco de dados (PostgreSQL + PostGIS) =====
# Bate com o docker-compose.yml deste repositório.
DATABASE_URL=postgresql://fleet:fleet@localhost:5432/fleet_cd
# Credenciais usadas pelo container do Postgres
POSTGRES_USER=fleet
POSTGRES_PASSWORD=fleet
POSTGRES_DB=fleet_cd

# ===== Redis (workers/filas) =====
REDIS_URL=redis://localhost:6379

# ===== Worker: detecção de "sem GPS" =====
# Varre viagens em andamento e gera o alerta sem_gps quando o veículo para de
# transmitir. Usa o Redis como lock (só uma instância roda por vez).
WORKER_SEM_GPS_ENABLED=true
WORKER_SEM_GPS_INTERVALO_S=60
WORKER_SEM_GPS_LIMITE_MIN=10

# ===== Integração SEFAZ (NF-e) — opcional =====
# Sem estas variáveis, POST /api/nfs/sefaz responde 501 (o import manual via
# POST /api/nfs/importar funciona sem certificado). Para habilitar a consulta:
#   - SEFAZ_CERT_PFX_PATH: caminho do certificado A1 (.pfx) — NUNCA versione o .pfx
#   - SEFAZ_CERT_PASSWORD: senha do certificado
#   - SEFAZ_UF: UF do web service (ex.: SP)
#   - SEFAZ_AMBIENTE: 1=produção, 2=homologação
# SEFAZ_CERT_PFX_PATH=
# SEFAZ_CERT_PASSWORD=
# SEFAZ_UF=SP
# SEFAZ_AMBIENTE=2

# ===== Autenticação JWT =====
# Gere segredos fortes para produção: `openssl rand -hex 32`
JWT_ACCESS_SECRET=troque-este-segredo-de-acesso
JWT_REFRESH_SECRET=troque-este-segredo-de-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_ROUNDS=12

# ===== Usuário administrador inicial (usado por `npm run seed`) =====
SEED_ADMIN_NOME=Administrador
SEED_ADMIN_EMAIL=admin@cd.local
SEED_ADMIN_SENHA=trocar-senha-123

# Map matching (encaixar GPS nas ruas). Padrão: instância pública gratuita FOSSGIS.
# Em produção, apontar para instância própria/paga (sem limite de uso).
MAPMATCH_VALHALLA_URL=https://valhalla1.openstreetmap.de
